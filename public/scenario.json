    {
      "type": "switchContext",
      "to": "dm",
      "dmWith": "takashi",
      "durationMs": 800
    },
    {
      "type": "message",
      "speaker": "umeko",
      "text": "たかしさん、お仕事おつかれさまです。\nあかねさんは寂しいんだと思います。\n「遅くなってごめん、◯曜は早く帰るね」\nって伝えると安心するかもです 😊",
      "time": "18:45",
      "effect": "glow",
      "durationMs": 3500
    },
    {
      "type": "message",
      "speaker": "takashi",
      "text": "そっか…ちょっと言い方きつかったな",
      "time": "18:46",
      "durationMs": 1500
    },
    {
      "type": "caption",
      "text": "それぞれが自分の言葉でグループに戻る",
      "style": "highlight",
      "durationMs": 1500
    },
    {
      "type": "switchContext",
      "to": "group",
      "durationMs": 800
    },
    {
      "type": "message",
      "speaker": "takashi",
      "text": "さっきはごめん。\n水曜は早く帰るから、ごはん一緒に食べよう",
      "time": "18:50",
      "durationMs": 2500
    },
    {
      "type": "message",
      "speaker": "akane",
      "text": "うん、楽しみにしてる ☺️",
